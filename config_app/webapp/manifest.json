{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.config.app.configapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.18.0",
      "toolsId": "cd7e1364-589e-4a10-90ab-55dd41b44669"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v2/Search-srv/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "semobject-Manage": {
          "semanticObject": "semobject",
          "action": "Manage",
          "title": "{{semobject-Manage.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.136.2",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.config.app.configapp.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "defaultBindingMode": "TwoWay"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.f.routing.Router",
        "controlAggregation": "beginColumnPages",
        "controlId": "fcl",
        "transition": "slide",
        "viewType": "XML",
        "async": true
      },
      "routes": [
        {
          "name": "RouteMain",
          "pattern": ":?query",
          "target": [
            "TargetMain"
          ],
          "layout": "OneColumn"
        },
        {
          "name": "Detail",
          "pattern": "searchDetail/{key}",
          "target": [
            "TargetDetail"
          ],
          "layout": "TwoColumnsMidExpanded"
        }
      ],
      "targets": {
        "TargetMain": {
          "viewId": "Main",
          "viewName": "com.config.app.configapp.view.Main",
          "controlAggregation": "beginColumnPages",
          "viewLevel": 0
        },
        "TargetDetail": {
          "viewId": "Detail",
          "viewName": "com.config.app.configapp.view.Detail",
          "controlAggregation": "midColumnPages",
          "viewLevel": 1
        }
      }
    },
    "rootView": {
      "viewName": "com.config.app.configapp.view.App",
      "type": "XML",
      "async": true
    },
    "config": {
      "fullWidth": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "Managed"
  }
}